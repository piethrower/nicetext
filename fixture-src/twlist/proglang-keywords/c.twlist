c_strerror         strerror

# ----- <ctype.h> built-ins -----
c_isalpha          isalpha
c_isdigit          isdigit
c_isalnum          isalnum
c_isspace          isspace
c_isupper          isupper
c_islower          islower
c_isprint          isprint
c_ispunct          ispunct
c_iscntrl          iscntrl
c_isxdigit         isxdigit
c_tolower          tolower
c_toupper          toupper

# ----- <math.h> built-ins -----
c_sin              sin
c_cos              cos
c_tan              tan
c_asin             asin
c_acos             acos
