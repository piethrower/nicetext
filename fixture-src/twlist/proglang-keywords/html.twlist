# ----- Interactive -----
html_details       details
html_summary       summary
html_dialog        dialog

# ----- Global / common attributes -----
# (style and title as attributes are the same word as the elements
# `<style>` / `<title>` above — no artificial disambiguator added.)
html_id            id
html_class         class
html_lang          lang
html_dir           dir
html_hidden        hidden
html_tabindex      tabindex
html_accesskey     accesskey
html_contenteditable contenteditable
html_draggable     draggable
html_spellcheck    spellcheck
html_translate     translate
html_role          role
html_data-         data-
html_aria-         aria-

