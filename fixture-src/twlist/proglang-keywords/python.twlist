python_exit        exit
python_filter      filter
python_float       float
python_format      format
python_frozenset   frozenset
python_getattr     getattr
python_globals     globals
python_hasattr     hasattr
python_hash        hash
python_help        help
python_hex         hex
python_id          id
python_input       input
python_int         int
python_isinstance  isinstance
python_issubclass  issubclass
python_iter        iter
python_len         len
python_list        list
python_locals      locals
python_map         map
python_max         max
python_memoryview  memoryview
python_min         min
python_next        next
python_object      object
python_oct         oct
python_open        open
python_ord         ord
python_pow         pow
python_print       print
python_property    property
python_quit        quit
python_range       range
python_repr        repr
python_reversed    reversed
python_round       round
python_self        self
python_cls         cls
python_set         set
python_setattr     setattr
python_slice       slice
python_sorted      sorted
python_staticmethod staticmethod
python_str         str
python_sum         sum
python_super       super
python_tuple       tuple
python_type        type
python_vars        vars
python_zip         zip

# ----- Dunder protocol (rule-2-rejected today; split fragments emit) -----
python___init__    __init__
python___new__     __new__
python___del__     __del__
python___repr__    __repr__
python___str__     __str__
python___bytes__   __bytes__
python___format__  __format__
python___lt__      __lt__
python___le__      __le__
python___eq__      __eq__
python___ne__      __ne__
python___gt__      __gt__
python___ge__      __ge__
python___hash__    __hash__
python___bool__    __bool__
python___getattr__ __getattr__
python___getattribute__ __getattribute__
python___setattr__ __setattr__
python___delattr__ __delattr__
python___dir__     __dir__
python___slots__   __slots__
python___class__   __class__
python___dict__    __dict__
python___name__    __name__
python___qualname__ __qualname__
python___module__  __module__
python___doc__     __doc__
python___file__    __file__
python___main__    __main__
python___all__     __all__
python___call__    __call__
python___len__     __len__
python___getitem__ __getitem__
python___setitem__ __setitem__
python___delitem__ __delitem__
python___iter__    __iter__
python___next__    __next__
python___contains__ __contains__
python___enter__   __enter__
