# proglang-keywords/python.twlist
#
# language: Python (CPython 3.x reserved keywords + built-in functions
# + built-in constants + dunder protocol identifiers).
# source: docs.python.org/3/reference/lexical_analysis.html (keywords),
#   docs.python.org/3/library/functions.html (built-in functions),
#   docs.python.org/3/reference/datamodel.html (dunder protocol).
# notes: dunder identifiers like __init__, __name__ are rule-2-rejected
#   (lexer punctuates `_`); authored for forward compat, split transform
#   synthesizes python_split_<word> fragments. Library functions
#   (numpy.array, os.path.join, etc.) are NOT included.

# ----- Python reserved keywords (PEP 3104 + 3.x additions) -----
python_false       false
python_none        none
python_true        true
python_and         and
python_as          as
python_assert      assert
python_async       async
python_await       await
python_break       break
python_class       class
python_continue    continue
python_def         def
python_del         del
python_elif        elif
python_else        else
python_except      except
python_finally     finally
python_for         for
python_from        from
python_global      global
python_if          if
python_import      import
python_in          in
python_is          is
python_lambda      lambda
python_nonlocal    nonlocal
python_not         not
python_or          or
python_pass        pass
python_raise       raise
python_return      return
python_try         try
python_while       while
python_with        with
python_yield       yield
python_match       match
python_case        case

# ----- Built-in constants -----
python_ellipsis    ellipsis
python_notimplemented notimplemented

# ----- Built-in functions (no-underscore; admit cleanly) -----
python_abs         abs
python_aiter       aiter
python_all         all
python_anext       anext
python_any         any
python_ascii       ascii
python_bin         bin
python_bool        bool
