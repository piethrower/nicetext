# ----- Constants and predefined identifiers -----
c++_null           null
c++_endl           endl
c++_npos           npos

# ----- std namespace fundamentals -----
# `std::*` qualified forms are rule-2-rejected (`::` PUNCTs split); the
# build synthesizes c++_split_<word> fragments. The bare unqualified
# identifiers are also listed below as standalone admitted rows.
c++_std::cout      std::cout
c++_std::cin       std::cin
c++_std::cerr      std::cerr
c++_std::endl      std::endl
c++_std::string    std::string
c++_std::vector    std::vector
c++_std::map       std::map
c++_std::pair      std::pair
c++_std::move      std::move
c++_std::forward   std::forward
c++_std::shared_ptr std::shared_ptr
c++_std::unique_ptr std::unique_ptr
c++_std::make_shared std::make_shared
c++_std::make_unique std::make_unique
c++_std            std
c++_cout           cout
c++_cin            cin
c++_cerr           cerr
c++_clog           clog
