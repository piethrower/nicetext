powershell-commands_default          default
powershell-commands_for              for
powershell-commands_foreach          foreach
powershell-commands_while            while
powershell-commands_do               do
powershell-commands_until            until
powershell-commands_break            break
powershell-commands_continue         continue
powershell-commands_return           return
powershell-commands_function         function
powershell-commands_param            param
powershell-commands_filter           filter
powershell-commands_workflow         workflow
powershell-commands_class            class
powershell-commands_enum             enum
powershell-commands_using            using
powershell-commands_try              try
powershell-commands_catch            catch
powershell-commands_finally          finally
powershell-commands_throw            throw
powershell-commands_trap             trap
powershell-commands_data             data
powershell-commands_dynamicparam     dynamicparam
powershell-commands_begin            begin
powershell-commands_process          process
powershell-commands_end              end
powershell-commands_inlinescript     inlinescript
powershell-commands_parallel         parallel
powershell-commands_sequence         sequence
powershell-commands_in               in

